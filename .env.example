# Server config
PORT=3001
HOST=127.0.0.1
JWT_SECRET=change-me-to-a-long-random-string
GEMINI_PATH=gemini
DB_PATH=./data/gemini-relay.db
CONTEXT_MESSAGES=20

# Gemini subprocess options
# GEMINI_SHELL=true   # Force shell:true when spawning Gemini (default: true on Windows, false elsewhere)
# GEMINI_DEBUG=1      # Enable verbose debug logging for Gemini subprocess I/O

# Web config (auto-detected in dev)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
